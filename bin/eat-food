  if [[ "$file_name" == "food" ]]; then
    printf """
   ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ     ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ     ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ    ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ    
 ‚ĖĄ‚ĖÄ   ‚ĖĎ  ‚ĖÄ‚ĖĄ ‚ĖĄ‚ĖÄ   ‚ĖĎ  ‚ĖÄ‚ĖĄ ‚ĖĄ‚ĖÄ   ‚ĖĎ  ‚ĖÄ‚ĖĄ ‚Ėą     ‚ĖÄ‚ĖÄ‚ĖĄ 
 ‚Ėą ‚ĖĎ‚ĖĄ‚ĖÄ‚ĖÄ‚ĖĄ ‚ĖĎ‚ĖĎ ‚Ėą ‚ĖĎ‚ĖĄ‚ĖÄ‚ĖÄ‚ĖĄ ‚ĖĎ‚ĖĎ ‚Ėą ‚ĖĎ‚ĖĄ‚ĖÄ‚ĖÄ‚ĖĄ ‚ĖĎ‚ĖĎ ‚Ėą ‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ   ‚Ėí
