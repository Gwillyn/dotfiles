animation() {
  printf "\r\033[K\n"
  local pid=$1
  printf "\e[?25l"
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r ."
    sleep 0.2
    printf "\r .."
    sleep 0.2
    printf "\r ..."
    sleep 0.2
    printf "\r    \r"

  done
  wait "$pid"
  local status=$?
  printf "\r\033[K\n"
  printf "\e[?25h"

  return "$status"
}

delete_food() {
  rm -rf -- "$HOME/Documents/$file_name"
  echo "Deleted."
  read -p "[Enter]" s
}

play() {
  cd ~/Documents/"$file_name"/
  clear
  logo
  printf "\nHow to play?"
  if [[ "$file_name" == "food" ]]; then
    printf """
    1: PlayAll
    2: Shuffle
    3: Randomizer
    4: File Manager
    5: Delete
    """
  else
    printf """
  1: PlayAll
  2: Shuffle
  4: File Manager
  5: Delete
  """
  fi

  read -p "> " ans

  case "$ans" in
  "" | 1)
    mpv . >/tmp/mpv-food.log 2>&1
    start
    ;;
  2)
    mpv --shuffle . >/tmp/mpv-food.log 2>&1
    start
    ;;
  3)
    if [[ "$file_name" == "g" ]]; then
      start
    fi
    python "$HOME/Documents/food/sort.py" --auto >/dev/null 2>&1 &
    pid=$!
    animation "$pid"
    start
    ;;
  4)
    kitty -e yazi "$HOME/Documents/$file_name" >/dev/null 2>&1 &
    start
    ;;
  5)
    delete_food
    start
    ;;

  *)
    echo "Invalid option"
    ;;
  esac
}

unzipper() {
  cd ~/Documents/
  if [[ ! -d "$file_name" ]]; then
    clear
    logo
    read -s -p "Password: " PASSWORD
    clear
    logo
    echo "Unzipping"
    UNZIP_DISABLE_ZIPBOMB_DETECTION=TRUE unzip -P "$PASSWORD" "$file_name.zip" -x "*.zip" -d "$file_name" >/dev/null 2>&1 &
    pid=$!

    if animation "$pid"; then
      echo "Unzipped"
    else
      echo "Failed to unzip"
    fi
    echo
    read -p "[Enter]" s
  fi
}

start() {
  unzipper
  play
}

start
