#!/usr/bin/env bash

clear
echo "Create Chromium Web App"
echo

read -rp "App name: " name
read -rp "Website URL: " url
read -rp "Icon path (optional): " icon

if [ -z "$name" ] || [ -z "$url" ]; then
  echo "App name and URL are required."
  exit 1
fi

if [[ "$url" != http://* && "$url" != https://* ]]; then
  url="https://$url"
fi

id="$(echo "$name" \
  | tr '[:upper:]' '[:lower:]' \
  | tr ' ' '-' \
  | tr -cd 'a-z0-9-')"

desktop="$HOME/.local/share/applications/$id.desktop"

mkdir -p "$HOME/.local/share/applications"

if [ -n "$icon" ]; then
  icon_line="Icon=$icon"
else
  icon_line="Icon=chromium"
fi

cat > "$desktop" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=$name
Exec=chromium --app=$url
$icon_line
Terminal=false
Categories=Network;WebBrowser;
StartupNotify=true
EOF

chmod +x "$desktop"
update-desktop-database "$HOME/.local/share/applications" 2>/dev/null

echo
echo "Created: $desktop"
echo "Launch with:"
echo "gtk-launch $id"
