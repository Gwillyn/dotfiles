#!/bin/bash

DEVICE="ftcs0038:00-2808:0106-touchpad"
STATE_FILE="/tmp/touchpad-disabled"

if [ -f "$STATE_FILE" ]; then
  hyprctl eval "hl.device({ name = \"$DEVICE\", enabled = true })"
  rm "$STATE_FILE"
else
  hyprctl eval "hl.device({ name = \"$DEVICE\", enabled = false })"
  touch "$STATE_FILE"
fi
