#!/bin/bash

set -e

REPO="$HOME/dotfiles/"

mkdir -p "$REPO"

# Configs
rsync -av --delete ~/.config/hypr/ "$REPO/hypr/"
rsync -av --delete ~/.config/waybar/ "$REPO/waybar/"
rsync -av --delete ~/.config/kitty/ "$REPO/kitty/"
rsync -av --delete ~/.config/tofi/ "$REPO/tofi/"
rsync -av --delete ~/.config/btop/ "$REPO/btop/"
rsync -av --delete ~/.config/nvim/ "$REPO/nvim/"
rsync -av --delete ~/.config/zed/ "$REPO/zed/"
rsync -av --delete ~/.config/zathura/ "$REPO/zathura/"
rsync -av --delete ~/.local/bin/ "$REPO/bin/"
rsync -av --delete ~/.config/obsidian/ "$REPO/obsidian/"

cp ~/.config/mimeapps.list "$REPO/mimeapps.list"

# Packages
pacman -Qqe >"$REPO/packages-all.txt"
pacman -Qqen >"$REPO/packages-pacman.txt"
pacman -Qqem >"$REPO/packages-aur.txt"

cd "$REPO"

git add .

if git diff --cached --quiet; then
  echo "Nothing to commit."
  exit 0
fi

git commit -m "Update configs and packages"
git push
